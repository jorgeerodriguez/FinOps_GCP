# ── Track ONLY Jupyter notebooks and repo essentials ──────────────────────
# Ignore everything by default
*

# Allow git to traverse subdirectories
!*/

# Track notebooks and repo files
!*.ipynb
!.gitignore
!README.md

# Always ignore Jupyter checkpoint folders (auto-generated by the kernel)
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ── Explicit safety exclusions (in case the wildcard above is changed) ─────
# Credentials & secrets
.env
*.key
*.pem
service_account*.json
application_default_credentials.json

# Large data files
*.csv
*.parquet
*.feather
*.pkl
*.json

# Output artifacts
*.html
*.png
*.jpg
*.pdf
*.xlsx
*.docx

# Python cache
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# macOS
.DS_Store
